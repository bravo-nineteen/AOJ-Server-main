# AOJ Command OS Environment Configuration
# Copy this to .env and customize for your environment

# ============================================
# API Configuration
# ============================================
HOST=0.0.0.0
PORT=8000
API_WORKERS=4
LOG_LEVEL=INFO

# ============================================
# Frontend Configuration
# ============================================
FRONTEND_PORT=5173
FRONTEND_HOST=0.0.0.0
API_BASE_URL=http://localhost:8000

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=sqlite:///./backend/aoj_command_os.db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ============================================
# LoRa Hardware Configuration
# ============================================
# Supported modes: mock, rpi_spi, usb_serial, test
LORA_MODE=mock

# For LORA_MODE=rpi_spi (Raspberry Pi 5 + Waveshare Core1262)
LORA_RPI_SPI_BUS=1
LORA_RPI_SPI_DEVICE=1
LORA_RPI_RST_PIN=17
LORA_RPI_DIO1_PIN=22
LORA_RPI_SPI_SPEED_HZ=8000000

# For LORA_MODE=usb_serial (Windows/Linux/macOS)
# Windows: COM3, COM4, COM5, etc.
# Linux: /dev/ttyUSB0, /dev/ttyUSB1, etc.
# macOS: /dev/tty.usbserial-XXXXX
LORA_USB_PORT=/dev/ttyUSB0
LORA_USB_BAUDRATE=9600
LORA_USB_TIMEOUT=1.0

# Legacy serial config (backward compatibility)
LORA_SERIAL_PORT=/dev/ttyUSB0
LORA_SERIAL_BAUDRATE=115200

# ============================================
# AI/LLM Configuration
# ============================================
# Set to 'true' to enable Ollama integration, 'false' for mock/offline mode
OLLAMA_ENABLED=false
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ============================================
# Text-to-Speech Configuration
# ============================================
# Supported engines: piper, pyttsx3 (piper preferred for offline use)
TTS_ENGINE=piper
PIPER_PATH=piper
PIPER_VOICE_DIR=./backend/assets/piper_voices
PIPER_VOICE_MODEL=en_US-amy-medium.onnx

# ============================================
# Authentication Configuration
# ============================================
# Set to 'true' to enable API key authentication
AUTH_ENABLED=false
# Format: comma-separated key:role pairs
# Example: key1:admin,key2:operator,key3:viewer
API_KEYS=

# ============================================
# CORS Configuration
# ============================================
# Regex pattern for allowed origins (default allows localhost and private IPs)
CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1|192\.168\.\d+\.\d+|10\.\d+\.\d+\.\d+|172\.(1[6-9]|2\d|3[0-1])\.\d+\.\d+)(:\d+)?

# ============================================
# Maintenance & Backups
# ============================================
BACKUP_DIR=./backend/backups
BACKUP_RETENTION_DAYS=30
AUTO_BACKUP_ENABLED=false
AUTO_BACKUP_SCHEDULE=0 2 * * *  # 2 AM daily (cron format)

# ============================================
# Deployment Mode
# ============================================
# Options: development, staging, production
DEPLOYMENT_MODE=development

# ============================================
# System Monitoring
# ============================================
ENABLE_METRICS=true
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL_SECONDS=30
