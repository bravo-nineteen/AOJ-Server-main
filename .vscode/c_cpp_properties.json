{
  "version": 4,
  "configurations": [
    {
      "name": "AOJ-Heltec-V3",
      "intelliSenseMode": "windows-gcc-x64",
      "cStandard": "c11",
      "cppStandard": "c++17",
      "includePath": [
        "${workspaceFolder}/**",
        "${workspaceFolder}/firmware/props/AOJ_Core",
        "${env:USERPROFILE}/Documents/Arduino/libraries/**",
        "${env:LOCALAPPDATA}/Arduino15/packages/**",
        "${env:LOCALAPPDATA}/Arduino15/packages/esp32/hardware/esp32/**",
        "${env:LOCALAPPDATA}/Arduino15/packages/esp32/tools/**"
      ],
      "defines": [
        "ARDUINO=10819",
        "ARDUINO_ARCH_ESP32",
        "ESP32",
        "BOARD_HELTEC_V3"
      ],
      "browse": {
        "path": [
          "${workspaceFolder}",
          "${env:USERPROFILE}/Documents/Arduino/libraries",
          "${env:LOCALAPPDATA}/Arduino15/packages"
        ],
        "limitSymbolsToIncludedHeaders": true
      }
    },
